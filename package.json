{
  "name": "ocularmp4",
  "version": "1.2.1",
  "private": true,
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11 <12"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "build": "npm run build:next && opennextjs-cloudflare build --skipNextBuild && node scripts/prepare-sites-dist.mjs",
    "build:next": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "test": "node --test tests/*.test.ts",
    "typecheck": "tsc --noEmit",
    "validate": "npm run lint && npm run test && npm run typecheck && npm run build",
    "version:check": "node scripts/check-version.mjs",
    "clean": "next clean"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@fontsource-variable/manrope": "^5.2.8",
    "autoprefixer": "^10.5.4",
    "clsx": "^2.1.1",
    "lucide-react": "^1.25.0",
    "motion": "^12.42.2",
    "mp4-muxer": "^5.2.2",
    "next": "^16.2.10",
    "postcss": "^8.5.19",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "webm-muxer": "^5.1.4"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@tailwindcss/postcss": "4.3.3",
    "@types/node": "^26.1.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "4.3.3",
    "typescript": "5.9.3",
    "wrangler": "^4.112.0"
  }
}
